# ─────────────────────────────────────────────────────────────────────────────
# CityPulse Logistics — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais committer .env dans le dépôt git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mistral AI ────────────────────────────────────────────────────────────────
# Clé API Mistral (https://console.mistral.ai)
# Préférer le stockage via OS keyring (paramètres > Configuration Mistral).
# Cette variable est un fallback si keyring est indisponible.
MISTRAL_API_KEY=your_mistral_api_key_here

# ── OSRM (Open Source Routing Machine) ───────────────────────────────────────
# URL du serveur OSRM. Laisser vide pour utiliser le serveur public.
# Exemple serveur local : http://localhost:5000
OSRM_URL=http://router.project-osrm.org
OSRM_TIMEOUT=10

# ── Traduction ────────────────────────────────────────────────────────────────
# Clé API DeepL (optionnel — fallback deep-translator)
DEEPL_API_KEY=

# ── Intégration site web (Django) ─────────────────────────────────────────────
# URL de l'API Django pour la synchronisation bidirectionnelle
DJANGO_API_URL=
DJANGO_API_KEY=

# ── Base de données ───────────────────────────────────────────────────────────
# Chemin personnalisé vers citypulse.db (laisser vide = dossier racine du projet)
DB_PATH=

# ── Logs ─────────────────────────────────────────────────────────────────────
# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
