# CityPulse Logistics — Configuration exemple
# Copiez ce fichier en .env et renseignez vos valeurs

# Clé API Mistral (recommandé : utiliser keyring OS à la place)
MISTRAL_API_KEY=your_mistral_api_key_here

# URL OSRM (laisser vide pour utiliser l'API publique)
# Pour production : OSRM self-hosted via Docker
CITYPULSE_OSRM_URL=http://router.project-osrm.org

# Timeout OSRM en secondes
CITYPULSE_OSRM_TIMEOUT=10
